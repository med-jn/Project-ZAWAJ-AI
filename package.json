{
  "name": "zawaj-ai",
  "type": "module",
  "version": "0.1.81",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --hostname 0.0.0.0",
    "build": "next build && node zip-build.js",
    "version:patch": "npm version patch --no-git-tag-version && node sync-version.js && npm run build",
    "version:minor": "npm version minor --no-git-tag-version && node sync-version.js && npm run build",
    "version:major": "npm version major --no-git-tag-version && node sync-version.js && npm run build",
    "deploy": "npm run version:patch && git add . && git commit -m \"Auto-Deploy: Update Version and Build\" && git push",
    "sync": "node sync-version.js",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@admob-plus/capacitor": "^2.0.0-alpha.4",
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/live-updates": "^0.5.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/generative-ai": "^0.24.1",
    "@headlessui/react": "^2.2.9",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "autoprefixer": "10.4.15",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^16.2.1",
    "postcss": "^8.5.8",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sonner": "^2.0.7",
    "tailwindcss": "3.3.3",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "20.6.2",
    "@types/react": "18.2.22",
    "@types/react-dom": "18.2.7",
    "archiver": "^7.0.1",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.1.6",
    "typescript": "5.2.2"
  }
}
