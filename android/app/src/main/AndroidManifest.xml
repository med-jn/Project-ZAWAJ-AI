<?xml version="1.0" encoding="utf-8"?>
<!--
    ملف أمان الشبكة
    يسمح بالاتصال بـ sandbox/preprod في بيئة التطوير فقط
    في الإنتاج: HTTPS فقط بدون استثناءات
-->
<network-security-config>

    <!-- بيئة التطوير: السماح بـ Konnect sandbox -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.preprod.konnect.network</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Supabase: HTTPS مضمون -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">lbftmbutvtjtkxgdbndu.supabase.co</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- OrcaVibe: HTTPS مضمون -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">orcavibe.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- القاعدة الافتراضية: HTTPS فقط لجميع النطاقات -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>